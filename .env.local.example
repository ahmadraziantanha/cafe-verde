# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin gate (any strong string — used by /admin login)
ADMIN_PASSWORD=change-me-to-something-strong
ADMIN_COOKIE_SECRET=another-long-random-string

# WhatsApp number that receives orders (digits only, with country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=96599999999
